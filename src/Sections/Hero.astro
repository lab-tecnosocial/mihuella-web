---
import Cellphone from "../assets/images/cellphone.webp";
import GoogleBtn from "../assets/images/GooglePlay Button.webp";
import HuellaHidricaBtn from "../assets/images/huella-hidrica.webp";
import AppStoreBtn from "../assets/images/AppStore Button.webp";
import WordHappyJump from "../assets/images/word-happy-yump.webp";
---


<main class="min-h-screen w-full bg-huella-text-gray-ligth flex flex-col overflow-x-hidden py-10 lg:py-0">
  
  <article class="w-full mx-auto px-4 lg:px-[5rem] flex flex-col lg:flex-row items-center gap-8 lg:gap-20 h-full">
    
    <div class="flex flex-col gap-6 items-start lg:w-[46.0625rem] lg:shrink-0 z-10 mt-[5rem]">
      
      <h1 class="font-sans text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold animate-fade-up leading-tight text-green-text-primary max-w-[46.0625rem]">
        Calcula tu huella de carbono e hídrica de forma fácil y amigable
      </h1>

      <div class="relative block lg:hidden w-full mx-auto mt-4 mb-2 animate-fade-up">
        <img
          src={WordHappyJump.src}
          alt="Imagen celular"
          class="max-h-[20rem] max-w-[20rem] h-auto drop-shadow-2xl block mx-auto"
          loading="eager"
        />

      </div>

      <p class="font-sans text-base lg:text-xl text-green-text-primary max-w-[37.5rem] text-pretty animate-fade-up animate-delay-100">
        Mi Huella calcula tu impacto a partir de tus hábitos de consumo, energía y transporte, y te muestra consejos prácticos para tomar decisiones más sostenibles en tu día a día.
      </p>

      <div class="flex flex-row flex-wrap gap-3 mt-0 w-full">
        <a
          href="https://play.google.com/store/apps/details?id=org.labtecnosocial.mihuella"
          class="transition-transform transform hover:scale-105 duration-300 w-[45%] max-w-[13.75rem] h-[3.9375rem]"
        >
          <img
            src={GoogleBtn.src}
            alt="Google play"
            width={184}
            height={63}
            loading="lazy"
            class="h-full w-full object-cover aspect-square"
          />
        </a>

        <a
          href="https://apps.apple.com/us/app/mi-huella-en-el-planeta/id6748420106"
          class="transition-transform transform hover:scale-105 duration-300 w-[45%] max-w-[11.875rem] h-[3.9375rem]"
        >
          <img
            src={AppStoreBtn.src}
            alt="App Store"
            width={160}
            height={50}
            loading="lazy"
            class="h-full w-full object-cover rounded-[0.625rem] aspect-square"
          />
        </a>
      </div>
    </div>

    <div class="hidden lg:flex flex-1 justify-center items-center relative right-[5.625rem] top-[10.625rem]">
      <div class="relative w-full">
          <img
            src={WordHappyJump.src}
            alt="Imagen celular"
            class="max-h-[40.75rem] max-w-[40.75rem] h-auto drop-shadow-2xl block mx-auto"
            loading="lazy"
          />
      </div>
    </div>

  </article>
</main>